# Frontend (Create React App) — copy to .env in project root

# Bind dev server to all interfaces (optional; CRA often does this already)
HOST=0.0.0.0

# API URL — leave unset to auto-match your browser host (recommended on Wi-Fi)
# Local only:
# REACT_APP_API_URL=http://localhost:8080
# Same PC via network IP (replace with your IP from "On Your Network"):
# REACT_APP_API_URL=http://10.79.108.89:8080

# Use http:// NOT https:// in the browser (dev has no SSL certificate).
# "Not secure" in Chrome for http:// is normal and expected in development.
